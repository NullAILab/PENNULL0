# ==============================================================
# penNULL — Environment Configuration Reference
# ==============================================================
#
# HOW TO USE:
#   cp .env.example .env
#   then fill in your values and run: docker compose up -d
#
# REQUIRED: at least one LLM provider (section below).
# EVERYTHING ELSE is optional unless you enable a specific stack.
#
# Generate random secrets with:
#   Linux/macOS : openssl rand -hex 32
#   Windows PS  : -join ((1..32) | ForEach { '{0:x2}' -f (Get-Random -Max 256) })
# ==============================================================


# ==============================================================
# LLM PROVIDERS
# ==============================================================
# Configure at least one provider. Multiple providers can be
# active at the same time — you choose which to use per assistant.

# -- OpenAI ---------------------------------------------------
OPEN_AI_KEY=                         # Your OpenAI API key (starts with sk-...)
OPEN_AI_SERVER_URL=https://api.openai.com/v1  # Change for Azure OpenAI or a proxy

# -- Anthropic (Claude) ---------------------------------------
ANTHROPIC_API_KEY=                   # Your Anthropic API key (starts with sk-ant-...)
ANTHROPIC_SERVER_URL=https://api.anthropic.com/v1

# -- Google AI (Gemini) ---------------------------------------
GEMINI_API_KEY=                      # Your Google AI Studio key (starts with AIza...)
GEMINI_SERVER_URL=https://generativelanguage.googleapis.com

# -- AWS Bedrock ----------------------------------------------
BEDROCK_REGION=us-east-1             # AWS region where Bedrock is available
# Choose ONE authentication method (priority: DefaultAuth > BearerToken > AccessKey):
BEDROCK_DEFAULT_AUTH=                # true = use AWS SDK credential chain
                                     #   (EC2 instance role, ~/.aws/credentials, env vars)
BEDROCK_BEARER_TOKEN=                # Bearer token authentication (alternative)
BEDROCK_ACCESS_KEY_ID=               # AWS access key ID (static credentials)
BEDROCK_SECRET_ACCESS_KEY=           # AWS secret access key (static credentials)
BEDROCK_SESSION_TOKEN=               # Session token for temporary STS credentials (optional)
BEDROCK_SERVER_URL=                  # Custom Bedrock endpoint — leave empty for default AWS endpoint

# -- DeepSeek -------------------------------------------------
DEEPSEEK_API_KEY=                    # DeepSeek API key from platform.deepseek.com
DEEPSEEK_SERVER_URL=https://api.deepseek.com
DEEPSEEK_PROVIDER=                   # LiteLLM provider prefix (e.g. "deepseek")
                                     # Leave empty for direct API access

# -- GLM (Zhipu AI) -------------------------------------------
GLM_API_KEY=                         # GLM API key from z.ai
GLM_SERVER_URL=https://api.z.ai/api/paas/v4
GLM_PROVIDER=                        # LiteLLM provider prefix (e.g. "zai")

# -- Kimi (Moonshot AI) ---------------------------------------
KIMI_API_KEY=                        # Moonshot API key from platform.moonshot.ai
KIMI_SERVER_URL=https://api.moonshot.ai/v1
KIMI_PROVIDER=                       # LiteLLM provider prefix (e.g. "moonshot")

# -- Qwen (Alibaba Cloud DashScope) ---------------------------
QWEN_API_KEY=                        # DashScope API key from dashscope.aliyun.com
QWEN_SERVER_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
QWEN_PROVIDER=                       # LiteLLM provider prefix (e.g. "dashscope")

# -- Custom / OpenAI-compatible endpoint ----------------------
# Use for: OpenRouter, DeepInfra, LiteLLM proxy, vLLM, Novita, etc.
LLM_SERVER_URL=                      # Base URL of the OpenAI-compatible API
LLM_SERVER_KEY=                      # API key for the custom provider
LLM_SERVER_MODEL=                    # Default model name — leave empty when using a config file
LLM_SERVER_PROVIDER=                 # Provider prefix for LiteLLM (e.g. "openrouter", "moonshot")
LLM_SERVER_CONFIG_PATH=              # Path inside container to a YAML agent-model config file
                                     # Example: /opt/pennull/conf/openrouter.provider.yml
LLM_SERVER_LEGACY_REASONING=         # Controls how reasoning parameters are sent to the LLM:
                                     #   false (default) = structured object with max_tokens (modern)
                                     #   true = string-based reasoning_effort (required for OpenAI API)
LLM_SERVER_PRESERVE_REASONING=       # true = keep reasoning_content in multi-turn message history
                                     # Required by some providers (e.g. Moonshot/Kimi) that error
                                     # when reasoning_content is missing in follow-up messages

# -- Ollama (local or Ollama Cloud) ---------------------------
# Local URLs:
#   Windows / macOS: http://host.docker.internal:11434
#   Linux (bridge) : http://172.17.0.1:11434
# Cloud URL: https://ollama.com
OLLAMA_SERVER_URL=http://host.docker.internal:11434
OLLAMA_SERVER_API_KEY=               # Required for Ollama Cloud — leave empty for local
OLLAMA_SERVER_MODEL=deepseek-r1:8b   # Default model (must have 110K+ context window)
                                     # Examples: llama3.1:8b-instruct-q8_0, qwen3:32b-fp16-tc
OLLAMA_SERVER_CONFIG_PATH=           # Path inside container to a YAML agent-model config file
                                     # Pre-built configs: /opt/pennull/conf/ollama-llama318b.provider.yml
OLLAMA_SERVER_PULL_MODELS_ENABLED=   # true = auto-download OLLAMA_SERVER_MODEL on container start
                                     # First run may take several minutes
OLLAMA_SERVER_PULL_MODELS_TIMEOUT=   # Seconds to wait for model download (default: 600)
OLLAMA_SERVER_LOAD_MODELS_ENABLED=true  # true = query Ollama API to discover available models on startup


# ==============================================================
# EMBEDDINGS
# ==============================================================
# Vector embeddings power semantic memory and search.
# IMPORTANT: use the same provider consistently — switching
# providers after data is stored requires a full reindex.
# Run: docker exec -it pennull /opt/pennull/bin/etester reindex

EMBEDDING_PROVIDER=ollama            # Options: openai | ollama | mistral | jina | huggingface | googleai | voyageai
EMBEDDING_MODEL=nomic-embed-text     # Model for the chosen provider
                                     # OpenAI: text-embedding-3-small | Ollama: nomic-embed-text
EMBEDDING_URL=http://host.docker.internal:11434  # API endpoint — leave empty to inherit from LLM provider
EMBEDDING_KEY=                       # API key — leave empty to inherit from LLM provider
EMBEDDING_BATCH_SIZE=128             # Documents to embed per batch (higher = faster but more memory)
EMBEDDING_STRIP_NEW_LINES=           # true = strip newlines from text before embedding
                                     # Improves quality for some models


# ==============================================================
# CONTEXT SUMMARIZER
# ==============================================================
# penNULL automatically compresses long conversations to stay
# within LLM token limits while preserving important context.

SUMMARIZER_PRESERVE_LAST=true        # true = always keep the last section of context intact
SUMMARIZER_USE_QA=true               # true = use question-answer pair summarization strategy
SUMMARIZER_SUM_MSG_HUMAN_IN_QA=true  # true = also summarize human messages in QA pairs
SUMMARIZER_LAST_SEC_BYTES=51200      # Max size of the last section in bytes (default: 50 KB)
SUMMARIZER_MAX_BP_BYTES=20000        # Max size of a single body pair before summarizing (~20 KB)
SUMMARIZER_MAX_QA_SECTIONS=10        # Max number of QA sections to keep in memory
SUMMARIZER_MAX_QA_BYTES=65536        # Max total size of all QA sections (default: 64 KB)
SUMMARIZER_KEEP_QA_SECTIONS=4        # Number of recent QA sections to keep without summarizing

# Assistant summarizer — overrides global settings for interactive assistants
ASSISTANT_SUMMARIZER_PRESERVE_LAST=true
ASSISTANT_SUMMARIZER_LAST_SEC_BYTES=76800   # 75 KB — larger window for interactive sessions
ASSISTANT_SUMMARIZER_MAX_BP_BYTES=16384     # 16 KB per body pair
ASSISTANT_SUMMARIZER_MAX_QA_SECTIONS=7
ASSISTANT_SUMMARIZER_MAX_QA_BYTES=76800     # 75 KB total QA sections
ASSISTANT_SUMMARIZER_KEEP_QA_SECTIONS=3


# ==============================================================
# ASSISTANT DEFAULTS
# ==============================================================

ASSISTANT_USE_AGENTS=true            # Default state of "Use Agents" when creating a new assistant:
                                     #   true  = multi-agent mode (Researcher → Developer → Executor → Reporter)
                                     #   false = single-agent mode
                                     # Users can override this per assistant in the UI

ASK_USER=true                        # true = allow agents to pause and ask the user for input
                                     # false = fully autonomous, no interruptions


# ==============================================================
# AGENT SUPERVISION (BETA)
# ==============================================================

# Execution Monitor — detects stuck or looping agents and injects guidance
EXECUTION_MONITOR_ENABLED=false      # true = enable automatic mentor agent intervention
                                     # Recommended for models < 32B parameters
                                     # Trade-off: ~2-3x more tokens, ~2x better results
EXECUTION_MONITOR_SAME_TOOL_LIMIT=5  # Trigger mentor after N identical consecutive tool calls
EXECUTION_MONITOR_TOTAL_TOOL_LIMIT=10  # Trigger mentor after N total tool calls without progress

# Planning Step — generates an execution plan before each subtask starts
AGENT_PLANNING_STEP_ENABLED=true     # true = planner agent creates 3-7 actionable steps
                                     # Recommended for models < 32B parameters
                                     # Reduces redundant work and scope creep

# Hard limits on tool calls per agent (always active)
MAX_GENERAL_AGENT_TOOL_CALLS=100     # Applies to: assistant, primary_agent, pentester, coder, installer
MAX_LIMITED_AGENT_TOOL_CALLS=20      # Applies to: searcher, enricher, memorist, reporter, adviser, reflector


# ==============================================================
# NETWORK & SECURITY
# ==============================================================

# Public access
PUBLIC_URL=https://localhost:8443    # Full URL where penNULL is reachable
                                     # Change for remote access: https://192.168.1.100:8443
CORS_ORIGINS=https://localhost:8443  # Comma-separated allowed CORS origins
                                     # Remote example: https://localhost:8443,https://192.168.1.100:8443

# Session cookie security
COOKIE_SIGNING_SALT=                 # ⚠ CHANGE THIS — random string for signing session cookies
                                     # Generate: openssl rand -hex 16

# HTTP proxy (optional)
PROXY_URL=                           # Global proxy for all outbound requests
                                     # Applies to: LLM APIs, search engines, scraper
                                     # Example: http://user:pass@proxy.example.com:8080

# TLS for outbound connections to LLM backends and tool servers
EXTERNAL_SSL_CA_PATH=                # Path inside container to a custom CA bundle (PEM format)
                                     # Must be under /opt/pennull/ssl/ (mounted via PENNULL_SSL_DIR)
                                     # Example: /opt/pennull/ssl/ca-bundle.pem
EXTERNAL_SSL_INSECURE=false          # true = skip TLS verification for outbound connections
                                     # ⚠ Development only — never use in production

# HTTP client timeout
HTTP_CLIENT_TIMEOUT=                 # Timeout in seconds for external API calls (default: 600)
                                     # Set to 0 for no timeout

# OAuth — GitHub (optional — enables "Login with GitHub")
OAUTH_GITHUB_CLIENT_ID=              # GitHub OAuth App Client ID
OAUTH_GITHUB_CLIENT_SECRET=          # GitHub OAuth App Client Secret
                                     # Create at: github.com → Settings → Developer settings → OAuth Apps

# OAuth — Google (optional — enables "Login with Google")
OAUTH_GOOGLE_CLIENT_ID=              # Google OAuth Client ID
OAUTH_GOOGLE_CLIENT_SECRET=          # Google OAuth Client Secret
                                     # Create at: console.cloud.google.com → APIs → Credentials


# ==============================================================
# SERVER SETTINGS
# ==============================================================

PENNULL_LISTEN_IP=0.0.0.0            # IP to bind penNULL on the host
                                     # 0.0.0.0 = all interfaces | 127.0.0.1 = localhost only
PENNULL_LISTEN_PORT=8443             # Port exposed on the host (maps to internal SERVER_PORT)
PENNULL_DATA_DIR=                    # Host path for persistent data (leave empty for Docker-managed volume)
PENNULL_SSL_DIR=                     # Host path for SSL files, mounted to /opt/pennull/ssl/ inside container
PENNULL_OLLAMA_DIR=                  # Host path for Ollama model storage (leave empty for Docker volume)
PENNULL_DOCKER_SOCKET=               # Host Docker socket path (default: /var/run/docker.sock)
PENNULL_DOCKER_CERT_PATH=            # Host path to Docker TLS certificates (for remote TCP connections)
PENNULL_LLM_SERVER_CONFIG_PATH=      # Host path to a custom LLM provider YAML config file
PENNULL_OLLAMA_SERVER_CONFIG_PATH=   # Host path to a custom Ollama provider YAML config file
PENNULL_IMAGE=                       # Override the penNULL Docker image tag (leave empty for default)

# Internal server settings (inside the container — do not change unless necessary)
STATIC_DIR=                          # Path to static frontend files inside container
STATIC_URL=                          # URL prefix for static files
SERVER_PORT=8443                     # Internal port (should match PENNULL_LISTEN_PORT)
SERVER_HOST=0.0.0.0
SERVER_SSL_CRT=                      # Path inside container to SSL certificate file
SERVER_SSL_KEY=                      # Path inside container to SSL private key file
SERVER_USE_SSL=true                  # true = serve HTTPS (uses self-signed cert by default)
                                     # false = plain HTTP (only for reverse-proxy setups)


# ==============================================================
# WEB SCRAPER
# ==============================================================
# penNULL uses an isolated Chromium browser container for
# gathering web intelligence during penetration tests.

SCRAPER_PUBLIC_URL=                  # Public URL for the scraper (for external target access)
                                     # Leave empty to use SCRAPER_PRIVATE_URL for all access
SCRAPER_PRIVATE_URL=https://someuser:somepass@scraper/  # Internal Docker URL
                                     # Format: https://USER:PASS@scraper/
                                     # For Podman rootless: http://USER:PASS@scraper:3000/
LOCAL_SCRAPER_USERNAME=someuser      # ⚠ CHANGE THIS — HTTP Basic Auth username for the scraper
LOCAL_SCRAPER_PASSWORD=somepass      # ⚠ CHANGE THIS — HTTP Basic Auth password for the scraper
LOCAL_SCRAPER_MAX_CONCURRENT_SESSIONS=10  # Max simultaneous browser sessions

# Scraper network binding (advanced — leave empty for defaults: 127.0.0.1:9443)
SCRAPER_LISTEN_IP=                   # Host IP to expose the scraper on (default: 127.0.0.1)
SCRAPER_LISTEN_PORT=                 # Host port to expose the scraper on (default: 9443)


# ==============================================================
# DATABASE (PostgreSQL + pgvector)
# ==============================================================

PENNULL_POSTGRES_USER=pennull        # PostgreSQL username
PENNULL_POSTGRES_PASSWORD=           # ⚠ CHANGE THIS — PostgreSQL password
                                     # Generate: openssl rand -hex 16
PENNULL_POSTGRES_DB=pennulldb        # PostgreSQL database name

# Network binding (advanced — leave empty for default localhost-only binding)
PGVECTOR_LISTEN_IP=                  # Host IP to expose PostgreSQL on (default: 127.0.0.1)
PGVECTOR_LISTEN_PORT=                # Host port for PostgreSQL (default: 5432)

# Postgres Exporter (Prometheus metrics — used by Grafana observability stack)
POSTGRES_EXPORTER_LISTEN_IP=
POSTGRES_EXPORTER_LISTEN_PORT=


# ==============================================================
# DOCKER AGENT SETTINGS
# ==============================================================
# penNULL spawns Docker containers to execute pentest tasks
# in isolation. These settings control how those containers run.

# Docker connection (to the Docker daemon)
DOCKER_HOST=                         # Docker API endpoint
                                     # Leave empty for local socket (/var/run/docker.sock)
                                     # Remote example: tcp://worker-node:2376
DOCKER_TLS_VERIFY=                   # 1 = verify Docker TLS certificates (required for remote TCP)
DOCKER_CERT_PATH=                    # Path to Docker TLS certificate directory

# Settings inside the primary terminal container
DOCKER_INSIDE=true                   # true = penNULL is running inside Docker (standard setup)
DOCKER_NET_ADMIN=true                # true = grant NET_ADMIN capability to task containers
                                     # Required for tools like nmap SYN scan, arp-scan, etc.
DOCKER_SOCKET=/var/run/docker.sock   # Docker socket path inside the penNULL container
DOCKER_NETWORK=                      # Docker network to attach task containers to (empty = auto)
DOCKER_WORK_DIR=                     # Working directory inside task containers (empty = default)
DOCKER_PUBLIC_IP=0.0.0.0             # Public IP reported to agents for OOB (out-of-band) callbacks
DOCKER_DEFAULT_IMAGE=                # Default image for general tasks (default: debian:latest)
DOCKER_DEFAULT_IMAGE_FOR_PENTEST=    # Default image for pentest tasks (default: nullailab/kali-linux)


# ==============================================================
# SEARCH ENGINES
# ==============================================================
# All search engines are optional. DuckDuckGo and Sploitus
# are free and need no API key.

# DuckDuckGo (free)
DUCKDUCKGO_ENABLED=true              # true = enable DuckDuckGo web search
DUCKDUCKGO_REGION=us-en              # Search region (e.g. us-en, uk-en, de-de, fr-fr)
DUCKDUCKGO_SAFESEARCH=off            # SafeSearch level: off | moderate | strict
DUCKDUCKGO_TIME_RANGE=               # Time filter: d (day) | w (week) | m (month) | y (year)
                                     # Leave empty = all time

# Sploitus (free — exploit and CVE database search)
SPLOITUS_ENABLED=                    # true = enable Sploitus exploit and CVE search

# Google Custom Search (requires API key)
GOOGLE_API_KEY=                      # Google API key from console.cloud.google.com
GOOGLE_CX_KEY=                       # Custom Search Engine ID from programmablesearchengine.google.com
GOOGLE_LR_KEY=                       # Language restriction (e.g. lang_en) — leave empty for all

# Traversaal AI search
TRAVERSAAL_API_KEY=                  # API key from traversaal.ai

# Tavily AI search (great for research and OSINT)
TAVILY_API_KEY=                      # API key from tavily.com

# Perplexity AI search
PERPLEXITY_API_KEY=                  # API key from perplexity.ai
PERPLEXITY_MODEL=                    # Model (e.g. sonar-pro) — leave empty for default
PERPLEXITY_CONTEXT_SIZE=             # Response size: small | medium | large — leave empty for default

# SearXNG (self-hosted meta search engine)
SEARXNG_URL=                         # URL of your SearXNG instance (e.g. http://searxng:8080)
SEARXNG_CATEGORIES=general           # Search categories (e.g. general,news,it,science)
SEARXNG_LANGUAGE=                    # Language filter (e.g. en) — leave empty for all languages
SEARXNG_SAFESEARCH=0                 # SafeSearch: 0 = off | 1 = moderate | 2 = strict
SEARXNG_TIME_RANGE=                  # Time range: day | week | month | year — leave empty for all
SEARXNG_TIMEOUT=                     # Request timeout in seconds — leave empty for default


# ==============================================================
# GRAPHITI KNOWLEDGE GRAPH (optional)
# ==============================================================
# Graphiti uses Neo4j to build a semantic graph of all agent
# interactions, enabling cross-session learning and contextual
# relationship tracking.
# Requires: docker-compose-graphiti.yml

GRAPHITI_ENABLED=false               # true = enable Graphiti integration
GRAPHITI_URL=                        # Graphiti API URL
                                     # When using docker-compose-graphiti.yml: http://graphiti:8000
GRAPHITI_TIMEOUT=30                  # Request timeout in seconds
GRAPHITI_MODEL_NAME=                 # LLM model for entity extraction (e.g. gpt-4.1-mini)
                                     # Requires OPEN_AI_KEY to be set

# Neo4j database (used by Graphiti)
NEO4J_USER=neo4j
NEO4J_DATABASE=neo4j
NEO4J_PASSWORD=                      # ⚠ CHANGE THIS — Neo4j password
                                     # Generate: openssl rand -hex 16
NEO4J_URI=bolt://neo4j:7687          # Neo4j Bolt URI (uses Docker service name)


# ==============================================================
# LANGFUSE — LLM OBSERVABILITY (optional)
# ==============================================================
# Langfuse records every LLM call: tokens, latency, cost,
# agent traces, and prompt versions. Access the UI at port 4000.
# Requires: docker-compose-langfuse.yml

# Connection from penNULL to Langfuse
LANGFUSE_BASE_URL=http://langfuse-web:3000  # Internal Docker URL (service name)
LANGFUSE_PROJECT_ID=                        # Auto-set from LANGFUSE_INIT_PROJECT_ID below
LANGFUSE_PUBLIC_KEY=                        # Auto-set from LANGFUSE_INIT_PROJECT_PUBLIC_KEY below
LANGFUSE_SECRET_KEY=                        # Auto-set from LANGFUSE_INIT_PROJECT_SECRET_KEY below

# Langfuse server binding
LANGFUSE_LISTEN_IP=0.0.0.0           # Host IP to expose Langfuse UI on
LANGFUSE_LISTEN_PORT=4000            # Host port for Langfuse UI (visit http://localhost:4000)

# Langfuse PostgreSQL (separate from penNULL's database)
LANGFUSE_POSTGRES_USER=postgres
LANGFUSE_POSTGRES_PASSWORD=          # ⚠ CHANGE THIS — Generate: openssl rand -hex 16
LANGFUSE_POSTGRES_DB=langfuse

# Langfuse ClickHouse (analytics and trace storage)
LANGFUSE_CLICKHOUSE_USER=clickhouse
LANGFUSE_CLICKHOUSE_PASSWORD=        # ⚠ CHANGE THIS — Generate: openssl rand -hex 16
LANGFUSE_CLICKHOUSE_URL=http://langfuse-clickhouse:8123
LANGFUSE_CLICKHOUSE_MIGRATION_URL=clickhouse://langfuse-clickhouse:9000
LANGFUSE_CLICKHOUSE_CLUSTER_ENABLED=false

# Langfuse MinIO (S3-compatible storage for media and events)
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_S3_REGION=auto
LANGFUSE_S3_ACCESS_KEY_ID=           # ⚠ CHANGE THIS — MinIO access key (any string, min 3 chars)
LANGFUSE_S3_SECRET_ACCESS_KEY=       # ⚠ CHANGE THIS — MinIO secret key (any string, min 8 chars)
                                     # Generate: openssl rand -hex 20
LANGFUSE_S3_ENDPOINT=http://langfuse-minio:9000
LANGFUSE_S3_FORCE_PATH_STYLE=true
LANGFUSE_S3_EVENT_UPLOAD_PREFIX=events/
LANGFUSE_S3_MEDIA_UPLOAD_PREFIX=media/
LANGFUSE_S3_BATCH_EXPORT_ENABLED=true

# Langfuse Redis (queue and rate limiting)
LANGFUSE_REDIS_HOST=langfuse-redis
LANGFUSE_REDIS_PORT=6379
LANGFUSE_REDIS_AUTH=                 # ⚠ CHANGE THIS — Redis password
                                     # Generate: openssl rand -hex 24
LANGFUSE_REDIS_TLS_ENABLED=false
LANGFUSE_REDIS_TLS_CA=
LANGFUSE_REDIS_TLS_CERT=
LANGFUSE_REDIS_TLS_KEY=

# Langfuse security keys
LANGFUSE_SALT=                       # ⚠ CHANGE THIS — Generate: openssl rand -hex 14
LANGFUSE_ENCRYPTION_KEY=             # ⚠ CHANGE THIS — Must be exactly 64 hex chars (32 bytes)
                                     # Generate: openssl rand -hex 32
LANGFUSE_NEXTAUTH_URL=http://localhost:4000  # Public URL for Langfuse UI (change for remote access)
LANGFUSE_NEXTAUTH_SECRET=            # ⚠ CHANGE THIS — Generate: openssl rand -hex 16

# Langfuse admin account (created automatically on first start)
LANGFUSE_INIT_ORG_ID=                # Leave empty to auto-generate
LANGFUSE_INIT_ORG_NAME=penNULL Org
LANGFUSE_INIT_PROJECT_ID=            # Leave empty to auto-generate
LANGFUSE_INIT_PROJECT_NAME=penNULL
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=    # ⚠ CHANGE THIS — Format: pk-lf-<uuid>
                                     # Generate: pk-lf-$(openssl rand -hex 16 | sed 's/.\{8\}/&-/;s/.\{13\}/&-/;s/.\{18\}/&-/;s/.\{23\}/&-/')
LANGFUSE_INIT_PROJECT_SECRET_KEY=    # ⚠ CHANGE THIS — Format: sk-lf-<uuid>
LANGFUSE_INIT_USER_EMAIL=admin@pennull.com
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=         # ⚠ CHANGE THIS — Langfuse admin password

# Langfuse feature flags
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true
LANGFUSE_TELEMETRY_ENABLED=false     # false = do not send usage statistics to Langfuse cloud
LANGFUSE_LOG_LEVEL=info              # Log verbosity: debug | info | warn | error

# Langfuse access control
LANGFUSE_AUTH_DISABLE_SIGNUP=true    # true = only admin can log in (recommended for self-hosted)
                                     # false = allow public signup
LANGFUSE_AUTH_SESSION_MAX_AGE=240    # Session lifetime in minutes (default: 4 hours)

LANGFUSE_ALLOWED_ORGANIZATION_CREATORS=admin@pennull.com  # Who can create organizations

# Default role for new users joining via OAuth/SSO
LANGFUSE_DEFAULT_ORG_ID=             # Match LANGFUSE_INIT_ORG_ID
LANGFUSE_DEFAULT_PROJECT_ID=         # Match LANGFUSE_INIT_PROJECT_ID
LANGFUSE_DEFAULT_ORG_ROLE=VIEWER     # Options: VIEWER | MEMBER | ADMIN
LANGFUSE_DEFAULT_PROJECT_ROLE=VIEWER # Options: VIEWER | MEMBER | ADMIN

# Langfuse custom OAuth2 / OIDC SSO (optional)
LANGFUSE_AUTH_CUSTOM_CLIENT_ID=
LANGFUSE_AUTH_CUSTOM_CLIENT_SECRET=
LANGFUSE_AUTH_CUSTOM_ISSUER=         # OIDC issuer URL (e.g. https://accounts.google.com)
LANGFUSE_AUTH_CUSTOM_NAME=penNULL    # SSO button label shown on login page
LANGFUSE_AUTH_CUSTOM_SCOPE=openid email profile
LANGFUSE_AUTH_CUSTOM_CLIENT_AUTH_METHOD=client_secret_post
LANGFUSE_AUTH_CUSTOM_ALLOW_ACCOUNT_LINKING=true

# Langfuse email notifications (optional)
LANGFUSE_EMAIL_FROM_ADDRESS=
LANGFUSE_SMTP_CONNECTION_URL=        # SMTP connection string (e.g. smtp://user:pass@mail.example.com:587)

# Langfuse ingestion performance tuning (leave empty for defaults)
LANGFUSE_INGESTION_QUEUE_DELAY_MS=
LANGFUSE_INGESTION_CLICKHOUSE_WRITE_INTERVAL_MS=
LANGFUSE_INGESTION_CLICKHOUSE_WRITE_BATCH_SIZE=
LANGFUSE_INGESTION_CLICKHOUSE_MAX_ATTEMPTS=

# Langfuse SDK settings
LANGFUSE_SDK_CI_SYNC_PROCESSING_ENABLED=false
LANGFUSE_READ_FROM_POSTGRES_ONLY=false
LANGFUSE_READ_FROM_CLICKHOUSE_ONLY=true
LANGFUSE_RETURN_FROM_CLICKHOUSE=true

# Langfuse enterprise license (optional — unlocks enterprise features)
LANGFUSE_EE_LICENSE_KEY=

# Langfuse Azure Blob Storage (alternative to MinIO)
LANGFUSE_USE_AZURE_BLOB=false

# Langfuse OpenTelemetry integration (connect to observability stack)
LANGFUSE_OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4318  # Internal OTEL collector URL
LANGFUSE_OTEL_SERVICE_NAME=


# ==============================================================
# OBSERVABILITY — GRAFANA / OPENTELEMETRY (optional)
# ==============================================================
# Full monitoring stack: metrics (VictoriaMetrics), distributed
# traces (Jaeger), and logs (Loki) — all in Grafana dashboards.
# Requires: docker-compose-observability.yml
# Access Grafana at: http://localhost:3000

# OpenTelemetry connection from penNULL
OTEL_HOST=otelcol:8148               # Internal OTEL gRPC endpoint (Docker service name + port)

# Grafana server binding
GRAFANA_LISTEN_IP=0.0.0.0            # Host IP to expose Grafana on
GRAFANA_LISTEN_PORT=3000             # Host port for Grafana UI (visit http://localhost:3000)

# OpenTelemetry Collector binding (advanced — leave empty for defaults)
OTEL_GRPC_LISTEN_IP=                 # Host IP for OTEL gRPC (default: 0.0.0.0)
OTEL_GRPC_LISTEN_PORT=               # Host port for OTEL gRPC (default: 4317)
OTEL_HTTP_LISTEN_IP=                 # Host IP for OTEL HTTP (default: 0.0.0.0)
OTEL_HTTP_LISTEN_PORT=               # Host port for OTEL HTTP (default: 4318)
